# Copy to .env and fill in values. Never commit .env to source control.

# SQLite database path (local: relative; Railway: /data/tracker.db on a volume)
TRACKER_DATABASE_PATH=data/tracker.db

# Gmail OAuth (local files; Railway: use GMAIL_*_B64 from scripts/export_railway_secrets.py)
GMAIL_CREDENTIALS_PATH=credentials/gmail_credentials.json
GMAIL_TOKEN_PATH=credentials/gmail_token.json
# GMAIL_CREDENTIALS_B64=
# GMAIL_TOKEN_B64=

# Email action recipient and SMTP (for email_kailin action)
KAILIN_EMAIL=kailinxu@hsl.harvard.edu
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=klx5505@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# Flask web dashboard
FLASK_SECRET_KEY=generate-a-random-secret
APP_URL=http://localhost:5000
